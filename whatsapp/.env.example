# URL of the running DREAM-Chat Flask server
FLASK_BASE_URL=http://localhost:8000

# Service account credentials for Flask API authentication
# The bot@dreamchat.local account is auto-seeded by Flask on startup.
# BOT_PASSWORD is REQUIRED and must match the BOT_PASSWORD env var on the Flask side.
# If BOT_PASSWORD is not set on the Flask side, Flask will generate a random one
# on first startup and print it to the console.
BOT_EMAIL=bot@dreamchat.local
BOT_PASSWORD=

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Optional SOCKS5/HTTP proxy for routing WhatsApp WebSocket traffic
# Required if running behind a firewall (e.g. mainland China)
# WA_PROXY_URL=socks5://127.0.0.1:7897

# ── Personal-number mode (default) ───────────────────────────────────────────
#
# ASSISTANT_HAS_OWN_NUMBER
#   Set to "true" only when the linked WhatsApp account is a dedicated bot
#   number that no human uses for personal messaging.
#   Default: false (personal-number mode)
# ASSISTANT_HAS_OWN_NUMBER=false

# ASSISTANT_NAME
#   Prefix added to every bot reply in personal-number mode so you can
#   distinguish bot messages from your own messages in the same thread.
#   Default: [Health Pal]
# ASSISTANT_NAME=[Health Pal]

# ── Internal Node.js REST API ─────────────────────────────────────────────────

# Port for the Express API server (connection management)
NODE_API_PORT=3001

# Shared secret for API authentication between Flask and Node.js
# Must match NODE_API_KEY on the Flask side
NODE_API_KEY=dreamchat-wa-secret

# Maximum concurrent WhatsApp connections (optional, default 50)
# MAX_CONNECTIONS=50
